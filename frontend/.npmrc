# Registry selection intentionally remains ambient so enterprise npmrc files
# can supply their required proxy, authentication, and internal registry.
fund=false
audit=false
# Cursor / agent sandboxes inject npm_config_devdir. npm 11+ prints
# `Unknown env config "devdir"` on stderr; Windows PowerShell with
# $ErrorActionPreference=Stop then aborts even when install exit code is 0.
# loglevel=error keeps real failures visible (and still prints the "added N
# packages" summary) while suppressing that spurious warn.
loglevel=error
