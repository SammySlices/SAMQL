{
  "name": "samql-frontend",
  "private": true,
  "version": "2.16.4",
  "type": "module",
  "description": "React frontend for SamQL with IDE, Journal, and NodeFlow workflows",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json --pretty false",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings 0",
    "check": "npm run typecheck && npm run lint && npm run build",
    "test:e2e": "playwright test",
    "test:e2e:edge": "node ./e2e/run-playwright-edge.mjs",
    "test:e2e:ui": "playwright test --ui",
    "test:component": "vitest run",
    "test:component:watch": "vitest",
    "test:frontend": "npm run test:component && npm run check",
    "test:release": "vitest run src/lib/releaseHardening.component.test.ts"
  },
  "dependencies": {
    "echarts": "^6.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.63.0",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10"
  },
  "packageManager": "npm@10.9.2"
}
